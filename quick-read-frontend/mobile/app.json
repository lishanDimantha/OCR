{
  "expo": {
    "name": "QuickRead",
    "slug": "quick-read-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quickreadfrontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quickread.frontend"
    },
    "android": {
      "package": "com.quickread.frontend",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "QuickRead needs access to your camera to scan prescriptions."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "QuickRead needs access to your photos to upload prescriptions.",
          "cameraPermission": "QuickRead needs access to your camera to take photos."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Logo.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#E6F4FE",
          "dark": {
            "backgroundColor": "#1a1a2e"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ]
  }
}
